# FinOptica MAN — variables d'environnement (copier vers .env)

APP_ENV=development
# production : active validate_security_settings() (secrets obligatoires)

SECRET_KEY=change-me-in-production
ALLOW_ANONYMOUS_AUTH=true
# false en production : Bearer obligatoire sur toutes les routes protégées

USE_DEMO_DATA=false
DATABASE_URL=sqlite:///./finoptica_dev.db
# PostgreSQL : postgresql+psycopg2://user:pass@host:5432/finoptica

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me
DEFAULT_TENANT_ID=tenant_enterprise_demo

ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

OPENAI_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o

SYNC_SCHEDULER_ENABLED=true
SYNC_DEFAULT_INTERVAL_MINUTES=360

OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback

REDIS_URL=
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main
